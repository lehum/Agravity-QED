Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"top1", "[", 
    RowBox[{"i_", ",", "j_"}], "]"}], ":=", 
   RowBox[{"CreateTopologies", "[", 
    RowBox[{"1", ",", 
     RowBox[{"i", "\[Rule]", "j"}], ",", 
     RowBox[{"ExcludeTopologies", "\[Rule]", 
      RowBox[{"{", "Reducible", "}"}]}], ",", 
     RowBox[{"Adjacencies", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"3", ",", "4", ",", "5"}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PhotonSelfEnergy", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"InsertFields", "[", 
       RowBox[{"#1", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"V", "[", "1", "]"}], "}"}], "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"V", "[", "1", "]"}], "}"}]}], ",", 
        RowBox[{"Sequence", "@@", "fields1"}], ",", 
        RowBox[{"ExcludeParticles", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"S", "[", "1", "]"}], ",", 
           RowBox[{"S", "[", "2", "]"}], ",", 
           RowBox[{"F", "[", "2", "]"}]}], "}"}]}]}], "]"}], "&"}], ")"}], 
    "[", 
    RowBox[{"top1", "[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Paint", "[", 
   RowBox[{"PhotonSelfEnergy", ",", 
    RowBox[{"ColumnsXRows", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"5", ",", "1"}], "}"}]}], ",", 
    RowBox[{"SheetHeader", "\[Rule]", 
     RowBox[{"{", "\"\<Photon self-energy\>\"", "}"}]}], ",", 
    RowBox[{"Numbering", "\[Rule]", "Simple"}], ",", 
    RowBox[{"ImageSize", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"600", ",", "200"}], "}"}]}]}], "]"}], ";"}]}], "Input",
